<Window x:Class="Voltaris.TestResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Voltaris · Результат" Width="780" Height="660" WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="NoResize" Background="#090E18" ShowInTaskbar="False">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="54"/><RowDefinition/></Grid.RowDefinitions>
        <Border Background="#0D1422" BorderBrush="#22324B" BorderThickness="1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid Margin="18,0,9,0"><TextBlock Text="Результат измерения" VerticalAlignment="Center" FontWeight="SemiBold"/><Button HorizontalAlignment="Right" Width="40" Height="34" Padding="0" Background="Transparent" BorderBrush="Transparent" Content="×" FontSize="20" Click="Close_Click"/></Grid>
        </Border>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="34,28,34,34">
                <Border Style="{StaticResource Card}" Background="#102337" BorderBrush="#2C7895" Padding="28">
                    <StackPanel HorizontalAlignment="Center">
                        <Ellipse Width="54" Height="54" Fill="#17394A" Stroke="#52E1BC" StrokeThickness="1"/>
                        <TextBlock Text="ИЗМЕРЕННАЯ ЁМКОСТЬ" Style="{StaticResource MetricLabel}" Foreground="{StaticResource AccentBrush}" Margin="0,16,0,0"/>
                        <TextBlock x:Name="CapacityText" Text="4 382 мА·ч" FontSize="42" FontWeight="SemiBold" Margin="0,7,0,0"/>
                        <TextBlock x:Name="AccuracyText" Text="Точность: высокая" Foreground="{StaticResource GoodBrush}" FontSize="12" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <Border Style="{StaticResource Card}" Margin="0,0,7,0" Padding="18"><StackPanel><TextBlock Text="ЭНЕРГИЯ" Style="{StaticResource MetricLabel}"/><TextBlock x:Name="EnergyText" Text="-- Вт·ч" FontSize="20" FontWeight="SemiBold" Margin="0,6,0,0"/></StackPanel></Border>
                    <Border Grid.Column="1" Style="{StaticResource Card}" Margin="7,0" Padding="18"><StackPanel><TextBlock Text="ВРЕМЯ" Style="{StaticResource MetricLabel}"/><TextBlock x:Name="DurationText" Text="--" FontSize="20" FontWeight="SemiBold" Margin="0,6,0,0"/></StackPanel></Border>
                    <Border Grid.Column="2" Style="{StaticResource Card}" Margin="7,0,0,0" Padding="18"><StackPanel><TextBlock Text="ДИАПАЗОН" Style="{StaticResource MetricLabel}"/><TextBlock x:Name="RangeText" Text="--" FontSize="20" FontWeight="SemiBold" Margin="0,6,0,0"/></StackPanel></Border>
                </Grid>

                <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                        <StackPanel Margin="0,0,0,16"><TextBlock Text="СРЕДНЕЕ НАПРЯЖЕНИЕ" Style="{StaticResource MetricLabel}"/><TextBlock x:Name="AvgVoltageText" Text="--" FontSize="17" FontWeight="SemiBold" Margin="0,4,0,0"/></StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,0,16"><TextBlock Text="СРЕДНЯЯ МОЩНОСТЬ" Style="{StaticResource MetricLabel}"/><TextBlock x:Name="AvgPowerText" Text="--" FontSize="17" FontWeight="SemiBold" Margin="0,4,0,0"/></StackPanel>
                        <StackPanel Grid.Row="1" Margin="0,0,0,16"><TextBlock Text="ПИКОВАЯ МОЩНОСТЬ" Style="{StaticResource MetricLabel}"/><TextBlock x:Name="PeakPowerText" Text="--" FontSize="17" FontWeight="SemiBold" Margin="0,4,0,0"/></StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,16"><TextBlock Text="СОБРАНО ТОЧЕК" Style="{StaticResource MetricLabel}"/><TextBlock x:Name="SamplesText" Text="--" FontSize="17" FontWeight="SemiBold" Margin="0,4,0,0"/></StackPanel>
                        <StackPanel Grid.Row="2"><TextBlock Text="ЗДОРОВЬЕ К ЗАВОДСКОЙ" Style="{StaticResource MetricLabel}"/><TextBlock x:Name="HealthText" Text="--" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource GoodBrush}" Margin="0,4,0,0"/></StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1"><TextBlock Text="ТИП ТЕСТА" Style="{StaticResource MetricLabel}"/><TextBlock x:Name="TypeText" Text="--" FontSize="17" FontWeight="SemiBold" Margin="0,4,0,0"/></StackPanel>
                    </Grid>
                </Border>

                <TextBlock x:Name="ResultHintText" Text="Результат сохранён локально и появился на главном экране." Foreground="{StaticResource MutedBrush}" FontSize="11" TextAlignment="Center" Margin="0,18,0,0"/>
                <Button Style="{StaticResource PrimaryButton}" Content="Готово" HorizontalAlignment="Center" Padding="35,12" Margin="0,15,0,0" Click="Close_Click"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>

