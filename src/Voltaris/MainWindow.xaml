<Window x:Class="Voltaris.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Voltaris Battery Lab" Width="1360" Height="800"
        MinWidth="1120" MinHeight="720" WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResize" Background="#070B14">
    <Window.Resources>
        <LinearGradientBrush x:Key="HeroGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#152B47" Offset="0"/>
            <GradientStop Color="#111B32" Offset="0.55"/>
            <GradientStop Color="#171A38" Offset="1"/>
        </LinearGradientBrush>
        <Style x:Key="SidebarButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
        </Style>
        <Style x:Key="TinyPill" TargetType="Border">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Background" Value="#16253B"/>
            <Setter Property="BorderBrush" Value="#29415F"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <RadialGradientBrush Center="0.82,0.06" GradientOrigin="0.82,0.06" RadiusX="0.75" RadiusY="0.8">
                <GradientStop Color="#18254B" Offset="0"/>
                <GradientStop Color="#070B14" Offset="0.62"/>
            </RadialGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="58"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0B111E" BorderBrush="#1C2A41" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid Margin="18,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Grid Width="31" Height="31">
                        <Ellipse Fill="#182D47" Stroke="#57E0FA" StrokeThickness="1"/>
                        <Path Data="M 10,21 L 15,9 L 18,15 L 22,15 L 16,23 L 14,18 Z" Fill="#65E6FF"/>
                    </Grid>
                    <TextBlock Text="VOLTARIS" Margin="11,0,0,0" VerticalAlignment="Center"
                               FontSize="16" FontWeight="Bold"/>
                    <Border Style="{StaticResource TinyPill}" Margin="10,0,0,0" Padding="7,3">
                        <TextBlock Text="BATTERY LAB" FontSize="9" Foreground="#80A1C8" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="Мониторинг аккумулятора" Foreground="{StaticResource MutedBrush}"
                           VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="12"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Width="44" Height="38" Padding="0" Background="Transparent" BorderBrush="Transparent"
                            Content="—" FontSize="16" Click="Minimize_Click"/>
                    <Button Width="44" Height="38" Padding="0" Background="Transparent" BorderBrush="Transparent"
                            Content="□" FontSize="15" Click="Maximize_Click"/>
                    <Button Width="44" Height="38" Padding="0" Background="Transparent" BorderBrush="Transparent"
                            Content="×" FontSize="20" Click="Close_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#0A101C" BorderBrush="#1C2A41" BorderThickness="0,0,1,0">
                <Grid Margin="18,22">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="РАБОЧАЯ ОБЛАСТЬ" Foreground="#64748C" FontSize="10" FontWeight="Bold" Margin="14,0,0,8"/>
                        <Button Style="{StaticResource SidebarButton}" Background="#142339" BorderBrush="#294867">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="◉" Foreground="{StaticResource AccentBrush}" Margin="0,0,12,0"/><TextBlock Text="Обзор" FontWeight="SemiBold"/></StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}" Click="ScrollToTest_Click">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="⌁" Margin="0,0,12,0"/><TextBlock Text="Тест ёмкости"/></StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}" Click="ExportHistory_Click">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="↗" Margin="0,0,12,0"/><TextBlock Text="Экспорт истории"/></StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Row="2">
                        <Border Style="{StaticResource Card}" Padding="15" CornerRadius="13" Background="#0F1A2A">
                            <StackPanel>
                                <TextBlock Text="СБОР ДАННЫХ" Style="{StaticResource MetricLabel}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,9,0,0">
                                    <Ellipse x:Name="LiveDot" Width="8" Height="8" Fill="{StaticResource GoodBrush}" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="LiveStateText" Text="Подключение…" FontSize="12"/>
                                </StackPanel>
                                <TextBlock Text="Обновление раз в секунду" Foreground="#65758E" FontSize="10" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="v1.0 · Windows 10/11" Foreground="#56657C" FontSize="10" HorizontalAlignment="Center" Margin="0,14,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer x:Name="MainScroll" Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="30,24,30,40" MaxWidth="1250">
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Состояние аккумулятора" FontSize="28" FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal" Margin="0,7,0,0">
                                <TextBlock x:Name="BatteryNameText" Text="Определение устройства…" Foreground="{StaticResource MutedBrush}" FontSize="13"/>
                                <TextBlock Text="  •  " Foreground="#53637B"/>
                                <TextBlock x:Name="LastUpdatedText" Text="ожидание данных" Foreground="{StaticResource MutedBrush}" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Style="{StaticResource TinyPill}" Margin="0,0,12,0">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="PowerDot" Width="8" Height="8" Fill="{StaticResource WarningBrush}" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="StatusText" Text="Подключение…" FontSize="12" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                            <Button x:Name="TestButton" Style="{StaticResource PrimaryButton}" Click="OpenTestWizard_Click" Content="Проверить реальную ёмкость"/>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.15*"/>
                            <ColumnDefinition Width="1.85*"/>
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource Card}" Background="{StaticResource HeroGradient}" Margin="0,0,14,0" MinHeight="300">
                            <Grid>
                                <Ellipse Width="220" Height="220" HorizontalAlignment="Left" VerticalAlignment="Center" Opacity="0.22">
                                    <Ellipse.Fill><RadialGradientBrush><GradientStop Color="#4BE6FF" Offset="0"/><GradientStop Color="Transparent" Offset="1"/></RadialGradientBrush></Ellipse.Fill>
                                </Ellipse>
                                <Grid Width="218" Height="218" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Ellipse Stroke="#243853" StrokeThickness="12"/>
                                    <Path x:Name="BatteryArc" Stroke="#62E5FF" StrokeThickness="12" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock x:Name="BatteryPercentText" Text="--%" FontSize="48" FontWeight="Light" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="BatteryStateText" Text="Ожидание" Foreground="{StaticResource AccentBrush}" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="RemainingText" Text="-- мВт·ч осталось" Foreground="{StaticResource MutedBrush}" FontSize="11" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <Border Style="{StaticResource Card}" Margin="0,0,7,7">
                                <StackPanel>
                                    <TextBlock Text="МОЩНОСТЬ" Style="{StaticResource MetricLabel}"/>
                                    <TextBlock x:Name="RateText" Text="-- Вт" Style="{StaticResource MetricValue}" Margin="0,8,0,0"/>
                                    <TextBlock Text="На клеммах батареи" Foreground="#667790" FontSize="11" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="7,0,0,7">
                                <StackPanel>
                                    <TextBlock Text="ТОК" Style="{StaticResource MetricLabel}"/>
                                    <TextBlock x:Name="CurrentText" Text="-- А" Style="{StaticResource MetricValue}" Margin="0,8,0,0"/>
                                    <TextBlock Text="Расчёт по P ÷ U" Foreground="#667790" FontSize="11" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,7,7,0">
                                <StackPanel>
                                    <TextBlock Text="НАПРЯЖЕНИЕ" Style="{StaticResource MetricLabel}"/>
                                    <TextBlock x:Name="VoltageText" Text="-- В" Style="{StaticResource MetricValue}" Margin="0,8,0,0"/>
                                    <TextBlock Text="Текущее напряжение" Foreground="#667790" FontSize="11" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Card}" Margin="7,7,0,0">
                                <StackPanel>
                                    <TextBlock Text="ТЕМПЕРАТУРА" Style="{StaticResource MetricLabel}"/>
                                    <TextBlock x:Name="TemperatureText" Text="Нет датчика" Style="{StaticResource MetricValue}" FontSize="20" Margin="0,8,0,0"/>
                                    <TextBlock x:Name="TemperatureHintText" Text="Не передаётся прошивкой" Foreground="#667790" FontSize="11" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <Border x:Name="ActiveTestPanel" Style="{StaticResource Card}" Margin="0,18,0,0" Background="#121F34" BorderBrush="#2C7895" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="ЗАМЕР РЕАЛЬНОЙ ЁМКОСТИ" Style="{StaticResource MetricLabel}" Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock x:Name="TestStateText" Text="Ожидание начала зарядки" FontSize="18" FontWeight="SemiBold" Margin="0,7,0,0"/>
                                <TextBlock x:Name="TestProgressText" Text="Подключите зарядное устройство" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,5,0,0"/>
                            </StackPanel>
                            <Button x:Name="FinishTestButton" Grid.Column="1" Content="Завершить частичный тест" VerticalAlignment="Center" IsEnabled="False" Click="FinishTest_Click"/>
                        </Grid>
                    </Border>

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="1.7*"/><ColumnDefinition Width="1*"/></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource Card}" Margin="0,0,14,0" Height="245">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition/></Grid.RowDefinitions>
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="Динамика зарядки" FontSize="17" FontWeight="SemiBold"/>
                                        <TextBlock Text="Мощность за последние 90 секунд" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Border HorizontalAlignment="Right" VerticalAlignment="Top" Style="{StaticResource TinyPill}">
                                        <TextBlock x:Name="ChartPeakText" Text="Пик -- Вт" FontSize="11"/>
                                    </Border>
                                </Grid>
                                <Canvas x:Name="ChartCanvas" Grid.Row="1" Margin="0,18,0,0" ClipToBounds="True" SizeChanged="ChartCanvas_SizeChanged">
                                    <Line X1="0" Y1="35" X2="1200" Y2="35" Stroke="#1E3048" StrokeDashArray="3,4"/>
                                    <Line X1="0" Y1="85" X2="1200" Y2="85" Stroke="#1E3048" StrokeDashArray="3,4"/>
                                    <Line X1="0" Y1="135" X2="1200" Y2="135" Stroke="#1E3048" StrokeDashArray="3,4"/>
                                    <Polyline x:Name="ChartLineGlow" Stroke="#326E85" StrokeThickness="8" Opacity="0.24" StrokeLineJoin="Round"/>
                                    <Polyline x:Name="ChartLine" Stroke="#62E5FF" StrokeThickness="2.5" StrokeLineJoin="Round"/>
                                </Canvas>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Паспорт батареи" FontSize="17" FontWeight="SemiBold"/>
                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                    <StackPanel Margin="0,0,8,14"><TextBlock Text="ЗАВОДСКАЯ ЭНЕРГИЯ" Style="{StaticResource MetricLabel}"/><TextBlock x:Name="DesignEnergyText" Text="--" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0"/></StackPanel>
                                    <StackPanel Grid.Column="1" Margin="8,0,0,14"><TextBlock Text="ПОЛНЫЙ ЗАРЯД" Style="{StaticResource MetricLabel}"/><TextBlock x:Name="FullEnergyText" Text="--" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0"/></StackPanel>
                                    <StackPanel Grid.Row="1" Margin="0,0,8,14"><TextBlock Text="ЗДОРОВЬЕ" Style="{StaticResource MetricLabel}"/><TextBlock x:Name="HealthText" Text="--" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource GoodBrush}" Margin="0,4,0,0"/></StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,14"><TextBlock Text="ХИМИЯ" Style="{StaticResource MetricLabel}"/><TextBlock x:Name="ChemistryText" Text="--" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0"/></StackPanel>
                                    <StackPanel Grid.Row="2"><TextBlock Text="ИСТОЧНИК" Style="{StaticResource MetricLabel}"/><TextBlock x:Name="PowerSourceText" Text="--" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0"/></StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,0"><TextBlock Text="ЦИКЛЫ ПРОШИВКИ" Style="{StaticResource MetricLabel}"/><TextBlock x:Name="FirmwareCyclesText" Text="--" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0"/></StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid x:Name="TestComparisonSection" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="1*"/></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource Card}" Margin="0,0,14,0">
                            <StackPanel>
                                <TextBlock Text="Заводская и измеренная ёмкость" FontSize="17" FontWeight="SemiBold"/>
                                <TextBlock Text="Единый пересчёт в мА·ч по напряжению батареи" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,4,0,18"/>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="60"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <Border Background="#131F31" BorderBrush="#263B56" BorderThickness="1" CornerRadius="14" Padding="18">
                                        <StackPanel><TextBlock Text="ЗАВОДСКАЯ" Style="{StaticResource MetricLabel}"/><TextBlock x:Name="OriginalCapacityText" Text="-- мА·ч" FontSize="29" FontWeight="SemiBold" Margin="0,8,0,0"/><TextBlock x:Name="OriginalEnergyHint" Text="По паспорту Windows" Foreground="#687991" FontSize="11" Margin="0,4,0,0"/></StackPanel>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="→" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="21" Foreground="#526B8D"/>
                                    <Border Grid.Column="2" Background="#112639" BorderBrush="#2C7895" BorderThickness="1" CornerRadius="14" Padding="18">
                                        <StackPanel><TextBlock Text="ИЗМЕРЕННАЯ" Style="{StaticResource MetricLabel}" Foreground="{StaticResource AccentBrush}"/><TextBlock x:Name="MeasuredCapacityText" Text="Тест не проводился" FontSize="25" FontWeight="SemiBold" Margin="0,8,0,0"/><TextBlock x:Name="MeasuredDateText" Text="Запустите первый замер" Foreground="#6F849E" FontSize="11" Margin="0,4,0,0"/></StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Циклы заряд–разряд" FontSize="17" FontWeight="SemiBold"/>
                                <TextBlock Text="Прошивка + наблюдение Voltaris" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,4,0,16"/>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <StackPanel><TextBlock Text="OEM" Style="{StaticResource MetricLabel}"/><TextBlock x:Name="CycleOemText" Text="--" FontSize="27" FontWeight="SemiBold" Margin="0,5,0,0"/></StackPanel>
                                    <StackPanel Grid.Column="1"><TextBlock Text="НАБЛЮДАЕТСЯ" Style="{StaticResource MetricLabel}"/><TextBlock x:Name="ObservedCyclesText" Text="0,00" FontSize="27" FontWeight="SemiBold" Margin="0,5,0,0"/></StackPanel>
                                </Grid>
                                <TextBlock Text="1 цикл = суммарный разряд на 100%, не обязательно за один раз." TextWrapping="Wrap" Foreground="#64758E" FontSize="10" Margin="0,14,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <TextBlock Text="Показания зависят от датчиков ACPI и контроллера батареи. Voltaris не изменяет режим питания и не управляет зарядкой."
                               Foreground="#596A82" FontSize="10" TextAlignment="Center" Margin="0,20,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
